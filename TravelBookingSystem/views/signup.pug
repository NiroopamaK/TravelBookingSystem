doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title TripZip - Sign Up
    link(rel="stylesheet" href="/css/signup.css")
  body
    .container
      .left-half
      .right-half
        .form-container
          img.logo(src="/assets/logo.jpg" alt="Logo")
          #formContent

            // Step 1
            form#signupStep1
              h2 Sign Up

              label Role
              select#signupRole(required)
                option(value="") Select Role
                option(value="ADMIN") Admin
                option(value="TRAVELLER") Traveller
                option(value="TRAVEL_AGENT") Travel Agent

              label First Name
              input#signupFirstName(type="text" placeholder="Enter First Name" required minlength="2")
              ul#signupFirstNameRules.rules.hidden
                li Cannot leave empty

              label Last Name
              input#signupLastName(type="text" placeholder="Enter Last Name" required minlength="2")
              ul#signupLastNameRules.rules.hidden
                li Cannot leave empty

              label Passport Number
              input#signupPassport(type="text" placeholder="Enter Passport Number" required minlength="8")
              ul#signupPassportRules.rules.hidden
                li Minimum 8 characters required

              label Address
              input#signupAddress(type="text" placeholder="Enter Address" required minlength="5")
              ul#signupAddressRules.rules.hidden
                li Cannot leave empty

              label Telephone Number
              .phone-group
                select#countryCode(required)
                  option(value="+1") 🇺🇸 +1
                  option(value="+44") 🇬🇧 +44
                  option(value="+91") 🇮🇳 +91
                  option(value="+94") 🇱🇰 +94
                input#signupTelephone(type="tel" placeholder="Enter Number" required pattern="[0-9]{7,12}")
              ul#signupTelephoneRules.rules.hidden
                li Enter 10 digits

              button#nextStepBtn.submit-btn(type="button" disabled) Create Account

            // Step 2
            form#signupStep2.hidden
              label Email
              input#signupEmail(type="email" placeholder="Enter Email" required)
              ul#emailRules.rules.hidden
                li Must be a valid email
              button#sendCodeBtn(type="button") Send Verification Code

              #afterCodeSent.hidden
                label Enter Verification Code
                input#emailCode(type="text" placeholder="Enter Code")
                button#validateCodeBtn(type="button") Validate Code
                p#validationMessage
                p#timerText
                  | Code expires in 
                  span#timer 60
                  | s
                button#resendCodeBtn.hidden(type="button") Resend Code

              #passwordSection.hidden
                label Password
                input#signupPassword(type="password" placeholder="Enter Password")
                ul#passwordRules.rules
                  li#ruleLength Minimum 8 characters
                  li#ruleUpper At least 1 uppercase letter
                  li#ruleLower At least 1 lowercase letter
                  li#ruleNumber At least 1 number
                  li#ruleSpecial At least 1 special character

                label Re-enter Password
                input#signupPassword2(type="password" placeholder="Re-enter Password")
                ul#password2Rules.rules.hidden
                  li Passwords must match

                button.submit-btn(type="submit" disabled id="finishBtn") Finish Registration

            button.signup-link(onclick="window.location.href='/'") Back to Login

    script(src="/js/emailVerification.js")
    script(src="/js/signup.js")