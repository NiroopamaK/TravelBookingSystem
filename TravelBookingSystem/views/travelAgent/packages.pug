extends ../layout

block head
  link(rel="stylesheet" href="/css/agent.css")

block content
  .packages-header
    h2 My Packages
    
  .packages-controls
    input#searchInput.search-input(type="text" placeholder="Enter search terms")
    select#filterDropdown.filter-dropdown
      option(value="") Dropdown text
      option(value="CONFIRMED") Confirmed
      option(value="COMPLETED") Completed
      option(value="CANCELLED") Cancelled
    button.create-btn#openPackageModalBtn Create package

  table#packagesTable
    thead
      tr
        th Trip ID
        th Package
        th Traveller
        th Dates
        th Status
        th Actions
    tbody#packagesBody

  .modal-overlay#tripModal
    .modal
      button.modal-close#closeTripModalBtn &times;
      h3#tripTitle Trip: -
      p#tripPackageName -
      span.trip-status-badge#tripStatus Status
      .trip-info-cards
        .trip-info-card
          span.info-label Start Date
          span.info-value#tripStartDate -
        .trip-info-card
          span.info-label End Date
          span.info-value#tripEndDate -
        .trip-info-card
          span.info-label Cost
          span.info-value#tripCost -


  .modal-overlay#packageModal
    .modal
      button.modal-close#closePackageModalBtn &times;
      h3#packageFormTitle Add New Package

      form#packageForm
        input#packageId(type="hidden" name="package_id")

        label Title
        input#title(type="text" name="title" placeholder="Enter package title" required)

        label Destination
        input#destination(type="text" name="destination" placeholder="Enter destination" required)

        label Start Date
        input#startDate(type="date" name="start_date" required)

        label End Date
        input#endDate(type="date" name="end_date" required)

        label Description
        textarea#description(name="description" placeholder="Enter package description" required)

        label Price ($)
        input#price(type="number" name="price" step="0.01" min="0" placeholder="Enter price" required)

        h4 Itinerary Items
        #itineraryList
          .itinerary-item
            input(type="text" name="itinerary_title[]" placeholder="Item title" required)
            textarea(name="itinerary_description[]" placeholder="Item description" required)

        button#addItineraryBtn(type="button") + Add Itinerary Item

        .form-actions
          button#submitPackageBtn.submit-btn(type="submit") Save Package
          button#cancelEditBtn.cancel-btn(type="button" style="display:none") Cancel

block scripts
  script(src="/js/agent-packages.js")
