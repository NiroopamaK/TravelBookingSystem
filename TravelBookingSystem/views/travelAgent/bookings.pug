extends ../layout

block head
  link(rel="stylesheet" href="/css/agent.css")

block content
  h2 Manage Bookings

  h3 All Bookings

  .filter-bar
    .autocomplete-wrapper
      input#filterTraveller(type="text" placeholder="Filter by traveller..." autocomplete="off")
      ul#filterTravellerList.autocomplete-list
    .autocomplete-wrapper
      input#filterPackage(type="text" placeholder="Filter by package..." autocomplete="off")
      ul#filterPackageList.autocomplete-list
    select#filterStatus
      option(value="") All Statuses
      option(value="PENDING") PENDING
      option(value="CONFIRMED") CONFIRMED
      option(value="COMPLETED") COMPLETED
      option(value="CANCELLED") CANCELLED
    button#applyFiltersBtn Apply Filters
    button#resetFiltersBtn Reset

  table#bookingsTable
    thead
      tr
        th Booking ID
        th Package
        th Traveller
        th Dates
        th Status
        th Actions
    tbody#bookingsBody

  .pagination#bookingsPagination

  .modal-overlay#bookingInfoModal
    .modal
      button.modal-close#closeBookingInfoModalBtn &times;
      .booking-info-card
        h3#bookingInfoId -
        p#bookingInfoName -
        span.booking-status-badge#bookingInfoStatus -
        .booking-info-grid
          .booking-info-box
            label Start Date
            p#bookingInfoStartDate -
          .booking-info-box
            label End Date
            p#bookingInfoEndDate -
          .booking-info-box
            label Cost
            p#bookingInfoCost -

  .modal-overlay#bookingModal
    .modal
      button.modal-close#closeBookingModalBtn &times;
      h3 Update Booking Status

      form#updateStatusForm
        input#modalBookingId(type="hidden" name="booking_id")

        label Booking ID
        p#modalBookingIdDisplay -

        label Status
        select#status(name="status" required)
          option(value="") Select Status
          option(value="CONFIRMED") CONFIRMED
          option(value="COMPLETED") COMPLETED
          option(value="CANCELLED") CANCELLED

        .form-actions
          button.submit-btn(type="submit") Update Status

block scripts
  script(src="/js/agent-bookings.js")
