doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title TripZip - Customers
    link(rel="stylesheet" href="/css/dashboard.css")

  body
    nav.top-nav
      .nav-left
        img.logo(src="/assets/logo.jpg" alt="Logo")
      .nav-right
        span.profile-name Agent
        .profile-dropdown-container
          img.profile-pic#profilePic(src="/assets/admin.png" alt="Profile")
          .dropdown-menu#dropdownMenu
            a#signOutBtn(href="#") Sign Out

    .dashboard-wrapper
      aside#sidebar
        a(href="/agent/packages") Packages
        a(href="/agent/bookings") Bookings
        a(href="/agent/customers") Customers

      .dashboard-content
        h2 Customers

        // ===== CUSTOMERS TABLE =====
        table#customersTable
          thead
            tr
              th user_id
              th first_name
              th last_name
              th email
              th passport
              th address
              th telephone
          tbody#customersBody

    script(src="/js/agent-customers.js")
