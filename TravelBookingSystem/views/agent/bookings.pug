h2 Manage Bookings

h3 All Bookings
table#bookingsTable
  thead
    tr
      th booking_id
      th user_id
      th package_id
      th packsize
      th additional_notes
      th total_price
      th status
      th Actions
  tbody#bookingsBody

//- ===== UPDATE BOOKING STATUS MODAL =====
.modal-overlay#bookingModal
  .modal
    button.modal-close#closeBookingModalBtn &times;
    h3 Update Booking Status

    form#updateStatusForm
      input#modalBookingId(type="hidden" name="booking_id")

      label Booking ID
      p#modalBookingIdDisplay -

      label Status
      select#status(name="status" required)
        option(value="") Select Status
        option(value="PENDING") PENDING
        option(value="CONFIRMED") CONFIRMED
        option(value="COMPLETED") COMPLETED
        option(value="CANCELLED") CANCELLED

      .form-actions
        button.submit-btn(type="submit") Update Status

script(src="/js/agent-bookings.js")
