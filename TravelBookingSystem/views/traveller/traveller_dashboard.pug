doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title Traveller Dashboard
    link(rel="stylesheet", href="/css/dashboard.css")
    link(rel="stylesheet", href="/css/traveller_dashboard.css")

  body
    // ===== TOP NAVBAR (shared) =====
    nav.top-nav
      .nav-left
        img.logo(src="/assets/logo.jpg", alt="Logo")
      .nav-right
        span.profile-name Tom
        span.profile-role TRAVELLER
        .profile-dropdown-container
          img.profile-pic#profilePic(src="/assets/avatar.png", alt="Profile")
          .dropdown-menu#dropdownMenu
            a(href="/frontend/edit-profile.html") Edit Profile
            a#signOutBtn(href="#") Sign Out

    .dashboard-wrapper

      aside#sidebar

      .dashboard-content
        h2.section-title My Bookings


        .stats
          .stat
            .stat-number#upcomingCount 0
            .stat-text Upcoming Trips

          .stat
            .stat-number#activeCount 0
            .stat-text Active Trips

          .stat
            .stat-number#completedCount 0
            .stat-text Completed Trips

        .table-card
          table.table
            thead
              tr
                th Package
                th Destination
                th Status
                th.table-right Actions

            tbody#bookingsTbody

        .center
          button.btn.btn-wide(type="button") Browse More Packages

    script(src="/js/dashboard.js")
    script(src="/js/traveller_dashboard.js")