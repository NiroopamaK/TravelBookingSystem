doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title Traveller Dashboard

    // shared layout css
    link(rel="stylesheet", href="/css/dashboard.css")
    // your page css (optional, keep for table/stats)
    link(rel="stylesheet", href="/css/traveller_dashboard.css")

  body
    // ===== TOP NAVBAR (shared) =====
    nav.top-nav
      .nav-left
        img.logo(src="/assets/logo.jpg", alt="Logo")
      .nav-right
        span.profile-name Tom
        span.profile-role TRAVELLER
        .profile-dropdown-container
          img.profile-pic#profilePic(src="/assets/avatar.png", alt="Profile")
          .dropdown-menu#dropdownMenu
            a(href="/frontend/edit-profile.html") Edit Profile
            a#signOutBtn(href="#") Sign Out

    // ===== MAIN DASHBOARD LAYOUT (shared) =====
    .dashboard-wrapper
      // Sidebar injected by JS into this container
      aside#sidebar

      // Main content
      .dashboard-content
        h1 Traveller Dashboard

        h2.section-title My Bookings

        .stats
          .stat
            .stat-number 2
            .stat-text Upcoming Trips

          .stat
            .stat-number 1
            .stat-text Active Trip

          .stat
            .stat-number 1
            .stat-text Completed Trip

        .table-card
          table.table
            thead
              tr
                th Package
                th Destination
                th Status
                th.table-right Actions
            tbody
              tr
                td Amazing Adventure Tour
                td Vietnam
                td
                  span.pill.pill-active Active
                td.table-right
                  button.btn.btn-ghost(type="button") Cancel
                  button.btn(type="button") View

              tr
                td Beach Getaway
                td Hawaii
                td
                  span.pill.pill-completed Completed
                td.table-right
                  button.btn(type="button") View

        .center
          button.btn.btn-wide(type="button") Browse More Packages

    // shared JS (builds sidebar + dropdown)
    script(src="/js/dashboard.js")