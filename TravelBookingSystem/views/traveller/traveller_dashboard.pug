extends ../layout

block head
  meta(name="viewport", content="width=device-width, initial-scale=1.0")
  link(rel="stylesheet", href="/css/traveller_dashboard.css")

block content
  h2.section-title My Bookings

  .stats
    .stat
      .stat-number#upcomingCount 0
      .stat-text Upcoming Bookings

    .stat
      .stat-number#activeCount 0
      .stat-text Active Bookings

    .stat
      .stat-number#completedCount 0
      .stat-text Completed Bookings

  .table-card
    table.table
      thead
        tr
          th Package
          th Destination
          th Status
          th.table-right Actions

      tbody#bookingsTbody

  .center
    button.btn.btn-wide(type="button") Browse More Packages

block scripts
  script(src="/js/traveller_dashboard.js")